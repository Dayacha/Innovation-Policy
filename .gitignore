# =============================================================================
# Innovation Policy Pipeline — .gitignore
# =============================================================================

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Config (contains API keys) ───────────────────────────────────────────────
config.yaml

# ── OS / IDE ──────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
.vscode/
.idea/
.claude/

# ── Test / coverage ───────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# =============================================================================
# Data — what to track vs. ignore
# =============================================================================
#
# TRACK (commit to git — others can see results without re-running):
#   Data/input/taxonomy/                  taxonomy reference files
#   Data/output/budget/results*           final budget extraction results
#   Data/output/reforms/output/           final reform panel & events
#
# IGNORE (large or regenerable — re-created by running the pipeline):
#   *.pdf                                 all PDFs (Finance Bills + Econ Surveys)
#   Data/input/surveys/kappa_catalog.json internal OECD API URLs
#   Data/processed/                       old output location (replaced by Data/output/)
#   Data/output/reforms/extracted_text/   raw PDF text (large, intermediate)
#   Data/output/reforms/reforms_json/     per-survey LLM output (large, intermediate)

# ── All PDFs (too large for git) ──────────────────────────────────────────────
*.pdf

# ── Survey catalog ─────────────────────────
#Data/input/surveys/kappa_catalog.json

# ── Old output location (replaced by Data/output/) ───────────────────────────
Data/processed/

# ── Intermediate pipeline outputs (large, regenerable) ───────────────────────
Data/output/reforms/extracted_text/
#Data/output/reforms/reforms_json*/

# ── Final results are NOT ignored — commit them so others can see them ────────
# Data/output/budget/results*    ← tracked
# Data/output/reforms/output/    ← tracked

Data/output/budget/ai_validation
Data/output/budget/full_text
Data/output/budget/intermediate
Data/output/budget/results.xlsx
