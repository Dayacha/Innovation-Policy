  "decision_rules": {
    "auto_include": [
      {
        "rule": "A core R&D phrase appears",
        "action": "Include as high-confidence relevant",
        "examples": "research and development; basic research; applied research; experimental development; industrial research; technological development; research infrastructure"
      },
      {
        "rule": "An institution keyword appears together with a budget instrument in the same line, row, paragraph, or table entry",
        "action": "Include as high-confidence relevant",
        "examples": "grant to national research council; transfer to academy of sciences; appropriation for innovation agency; capital expenditure for research laboratory; institutional funding for university research"
      },
      {
        "rule": "An innovation/commercialisation term appears with a technology/research anchor",
        "action": "Include as high-confidence relevant",
        "examples": "innovation fund for technology startups; proof of concept grants; technology transfer programme; collaborative research with industry; prototype and demonstration support"
      },
      {
        "rule": "A sectoral research term appears with a budget instrument",
        "action": "Include as high-confidence relevant",
        "examples": "agricultural research programme; climate research grants; medical research fund; AI research centre allocation"
      }
    ],
    "review_needed": [
      {
        "rule": "Only 'innovation' appears",
        "action": "Review manually",
        "examples": "Too noisy on its own"
      },
      {
        "rule": "Only 'technology' appears",
        "action": "Review manually",
        "examples": "Too noisy on its own"
      },
      {
        "rule": "Only 'university' appears",
        "action": "Review manually",
        "examples": "Teaching and operations are common false positives"
      },
      {
        "rule": "Only 'laboratory' appears",
        "action": "Review manually",
        "examples": "May refer to routine diagnostics or service labs"
      },
      {
        "rule": "Only 'development' appears",
        "action": "Review manually",
        "examples": "Very noisy"
      }
    ],
    "exclude": [
      {
        "rule": "Development is preceded by regional / rural / urban / local / community",
        "action": "Exclude unless strong positive override exists",
        "examples": "regional development; rural development; urban development"
      },
      {
        "rule": "Innovation is preceded by administrative / organisational / service / pedagogical / classroom",
        "action": "Exclude unless strong positive override exists",
        "examples": "administrative innovation; service innovation"
      },
      {
        "rule": "Research is preceded by market / consumer / opinion / policy / survey",
        "action": "Exclude unless strong positive override exists",
        "examples": "market research; policy research; survey research"
      },
      {
        "rule": "Laboratory appears only in a routine diagnostics or clinical services context",
        "action": "Exclude unless strong positive override exists",
        "examples": "diagnostic lab services"
      }
    ]
  }
