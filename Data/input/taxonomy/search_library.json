  "decision_rules": {
    "auto_include": [
      {
        "rule": "A core R&D phrase appears",
        "action": "Include as high-confidence relevant",
        "examples": "research and development; basic research; applied research; experimental development; industrial research; technological development; research infrastructure"
      },
      {
        "rule": "An institution keyword appears together with a budget instrument in the same line, row, paragraph, or table entry",
        "action": "Include as high-confidence relevant",
        "examples": "grant to national research council; transfer to academy of sciences; appropriation for innovation agency; capital expenditure for research laboratory; institutional funding for university research"
      },
      {
        "rule": "An innovation/commercialisation term appears with a technology/research anchor",
        "action": "Include as high-confidence relevant",
        "examples": "innovation fund for technology startups; proof of concept grants; technology transfer programme; collaborative research with industry; prototype and demonstration support"
      },
      {
        "rule": "A sectoral research term appears with a budget instrument",
        "action": "Include as high-confidence relevant",
        "examples": "agricultural research programme; climate research grants; medical research fund; AI research centre allocation"
      }
    ],
    "review_needed": [
      {
        "rule": "Only 'innovation' appears",
        "action": "Review manually",
        "examples": "Too noisy on its own"
      },
      {
        "rule": "Only 'technology' appears",
        "action": "Review manually",
        "examples": "Too noisy on its own"
      },
      {
        "rule": "Only 'university' appears",
        "action": "Review manually",
        "examples": "Teaching and operations are common false positives"
      },
      {
        "rule": "Only 'laboratory' appears",
        "action": "Review manually",
        "examples": "May refer to routine diagnostics or service labs"
      },
      {
        "rule": "Only 'development' appears",
        "action": "Review manually",
        "examples": "Very noisy"
      },
      {
        "rule": "If dual-use / security / critical technology appears and the beneficiary is unclear",
        "action": "Review and consider coding as Dual-use",
        "examples": "dual-use research; security research; strategic technology"
      }
    ],
    "exclude": [
      {
        "rule": "Development is preceded by regional / rural / urban / local / community",
        "action": "Exclude unless strong positive override exists",
        "examples": "regional development; rural development; urban development"
      },
      {
        "rule": "Innovation is preceded by administrative / organisational / service / pedagogical / classroom",
        "action": "Exclude unless strong positive override exists",
        "examples": "administrative innovation; service innovation"
      },
      {
        "rule": "Research is preceded by market / consumer / opinion / policy / survey",
        "action": "Exclude unless strong positive override exists",
        "examples": "market research; policy research; survey research"
      },
      {
        "rule": "Laboratory appears only in a routine diagnostics or clinical services context",
        "action": "Exclude unless strong positive override exists",
        "examples": "diagnostic lab services"
      },
      {
        "rule": "Defence or security spending with procurement / operations / readiness / personnel but no research anchor",
        "action": "Exclude unless strong positive override exists",
        "examples": "weapons procurement; military operations; force readiness"
      }
    ],
    "auto_classify": [
      {
        "rule": "If basic / fundamental / frontier / curiosity-driven appears near research",
        "action": "Code as Basic research",
        "examples": "basic research; fundamental research; frontier research; curiosity-driven research"
      },
      {
        "rule": "If applied / industrial / translational / use-inspired / mission-oriented appears near research",
        "action": "Code as Applied research",
        "examples": "applied research; industrial research; translational research; use-inspired research"
      },
      {
        "rule": "If experimental development / prototype / testbed / pilot / demonstration / validation appears with R&D anchors",
        "action": "Code as Experimental development",
        "examples": "experimental development; prototype development; pilot plant; demonstration project; testbed"
      },
      {
        "rule": "If innovation / adoption / diffusion / incubator / accelerator / voucher appears without a core R&D phrase",
        "action": "Code as Innovation (not R&D)",
        "examples": "innovation voucher; startup support; technology diffusion; incubator; accelerator"
      },
      {
        "rule": "If defence / military / armed forces / ministry of defence appears near research or innovation",
        "action": "Code defence scope as Defence",
        "examples": "defence R&D; military research; defence innovation; defence laboratory"
      },
      {
        "rule": "If civilian / non-military / non-defence appears near research or innovation, or clearly civilian sectors with no defence anchor",
        "action": "Code defence scope as Non-defence",
        "examples": "civilian R&D; health research; agricultural research; civilian innovation"
      },
      {
        "rule": "Record both an activity code and a defence-scope code for every retained hit",
        "action": "Apply everywhere",
        "examples": "Activity: Basic / Applied / Experimental development / General R&D / Innovation / Bridge / Infrastructure / System support; Defence scope: Defence / Non-defence / Dual-use / Unspecified"
      }
    ]
  },
