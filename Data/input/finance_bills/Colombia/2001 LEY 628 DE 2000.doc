    .alerta-flotante {
      position: fixed;
      bottom: 20px;
      right: 20px;
      background-color: #004AAD;
      color: white;
      padding: 15px 20px;
      border-radius: 10px;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-width: 250px;
    }

    .alerta-flotante .cerrar {
      margin-left: 15px;
      font-weight: bold;
      cursor: pointer;
      color: white;
    }

    .alerta-flotante .cerrar:hover {
      color: #ffdddd;
    }
