.card {
  width: 100%;
  height: 100%;
  padding: 15px;
  border: 1px solid #ccc;
  border-radius: 8px;
  box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
  color: white;
  text-align: center;
 background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
}

.card p {
  font-size: 16px;
  color: white;
padding: inherit;
}

.card a {
  font-size: 16px;
  color: white;
  
}

.slider {
  width: 100%;
  height: var(--height);
  overflow: hidden;
  mask-image: linear-gradient(to right, transparent, #000 10% 90%, transparent);
}
.slider .list {
  display: flex;
  width: 100%;
  min-width: calc(var(--width) * var(--quantity));
  position: relative;
}
.slider .list .item {
  width: var(--width);
  height: var(--height);
  position: absolute;
  left: 100%;
  animation: autoRun 10s linear infinite;
  transition: filter 0.5s;
  animation-delay: calc(
    (10s / var(--quantity)) * (var(--position) - 1) - 10s
  ) !important;
}
.slider .list .item img {
  width: 100%;
}
@keyframes autoRun {
  from {
    left: 100%;
  }
  to {
    left: calc(var(--width) * -1);
  }
}
.slider:hover .item {
  animation-play-state: paused !important;
  filter: grayscale(1);
}
.slider .item:hover {
  filter: grayscale(0);
}
.slider[reverse="true"] .item {
  animation: reversePlay 10s linear infinite;
}
@keyframes reversePlay {
  from {
    left: calc(var(--width) * -1);
  }
  to {
    left: 100%;
  }
}
		
		
		
		
		
		
		</style></head><body class="documento_cms"><button aria-expanded="false" aria-haspopup="dialog" aria-label="Buscar en el diccionario" class="fab" id="toolFab" title="Buscar en el diccionario"><span style="color:white;font-size:12px;line-height:12px;display:block;">A-Z</span><svg aria-hidden="true" fill="none" height="24" viewBox="0 0 24 24" width="24"><path d="M4 5C4 4.44772 4.44772 4 5 4H11C12.1046 4 13 4.89543 13 6V20H6C4.89543 20 4 19.1046 4 18V5Z" stroke="white" stroke-width="1.8"></path><path d="M20 5C20 4.44772 19.5523 4 19 4H13C11.8954 4 11 4.89543 11 6V20H18C19.1046 20 20 19.1046 20 18V5Z" stroke="white" stroke-width="1.8"></path></svg></button><div aria-label="Herramientas" aria-modal="false" class="panel" hidden="hidden" id="toolPanel" role="dialog"><div class="panel-hd"><div class="panel-title">Diccionario</div><button aria-label="Cerrar" class="icon-btn" id="toolClose">X</button></div><div class="carddic"><div class="row"><input aria-label="Término" id="raeTerm" placeholder="Buscar palabra…" type="search"><button class="btn primary" onclick="openRAE('dle')" type="button">RAE</button></div><div class="note">Se abrirá en una nueva pestaña.</div></div></div><style type="text/css">
  /* Botón flotante */
  .fab{
    position: fixed;
    right: 18px;
    bottom: 18px;
    width: 54px;
    height: 54px;
    border-radius: 16px;
    border: 0;
    background: #0b3a7e;
    color: #fff;
    font-size: 22px;
    box-shadow: 0 10px 24px rgba(0,0,0,.18);
    cursor: pointer;
    z-index: 99999;
  }
  .fab:focus{ outline: none; box-shadow: 0 0 0 4px rgba(11,58,126,.20), 0 10px 24px rgba(0,0,0,.18); }

  /* Panel lateral */
  .panel{
    position: fixed;
    right: 18px;
    bottom: 84px;
    width: 360px;
    max-width: calc(100vw - 36px);
    max-height: calc(100vh - 120px);
    overflow: auto;
    border: 1px solid #e6e9ef;
    border-radius: 16px;
    background: #fff;
    box-shadow: 0 14px 40px rgba(0,0,0,.16);
    z-index: 99999;
    transform-origin: bottom right;
    animation: pop .12s ease-out;
  }
  @keyframes pop{ from{ transform: scale(.96); opacity:.2 } to{ transform: scale(1); opacity:1 } }

  .panel-hd{
    position: sticky;
    top: 0;
    background: #fff;
    display:flex;
    align-items:center;
    justify-content: space-between;
    padding: 12px 12px 10px 12px;
    border-bottom: 1px solid #eef1f6;
    border-top-left-radius: 16px;
    border-top-right-radius: 16px;
  }
  .panel-title{ font-weight: 700; color:#1b2430; }
  .icon-btn{
    border: 1px solid #d8dee9;
    background: #fff;
    border-radius: 10px;
    width: 34px; height: 34px;
    cursor:pointer;
  }

  .carddic{
    margin: 12px;
    padding: 12px;
    border: 1px solid #eef1f6;
    border-radius: 14px;
    background: #fff;
  }
  .card-title{ font-weight: 700; margin-bottom: 10px; color:#1b2430; }

  .row{ display:flex; gap:8px; align-items:center; }
  .row input{
    flex: 1;
    padding: 10px 12px;
    border: 1px solid #d8dee9;
    border-radius: 12px;
    font-size: 14px;
  }
  .row input:focus{
    outline: none;
    border-color:#0b3a7e;
    box-shadow: 0 0 0 3px rgba(11,58,126,.12);
  }

  .btn{
    padding: 10px 10px;
    border-radius: 12px;
    font-size: 13px;
    cursor:pointer;
    border: 1px solid transparent;
    white-space: nowrap;
  }
  .btn.primary{ background:#0b3a7e; color:#fff; }
  .btn.ghost{ background:#f3f6fb; color:#0b3a7e; border-color:#d8dee9; }

  .chips{ display:flex; gap:8px; flex-wrap:wrap; margin-top: 10px; }
  .chip{
    border: 1px solid #d8dee9;
    background: #fff;
    border-radius: 999px;
    padding: 6px 10px;
    font-size: 12px;
    cursor: pointer;
    color:#243041;
  }
  .chip:hover{ background:#f7f9fc; }
  .note{ margin-top: 10px; font-size: 12px; color:#5b6678; }

  .quick{ display:flex; gap:8px; flex-wrap:wrap; }
  .link{
    display:inline-flex;
    padding: 8px 10px;
    border-radius: 12px;
    border: 1px solid #d8dee9;
    text-decoration:none;
    color:#0b3a7e;
    background:#fff;
    font-size: 13px;
  }
  .link:hover{ background:#f7f9fc; }

  @media (max-width: 520px){
    .row{ flex-direction: column; align-items: stretch; }
    .btn{ width: 100%; }
  }
</style><script type="text/javascript">
  var fab = document.getElementById('toolFab');
  var panel = document.getElementById('toolPanel');
  var closeBtn = document.getElementById('toolClose');

  function openPanel(){
    panel.hidden = false;
    fab.setAttribute('aria-expanded', 'true');
    setTimeout(function(){
      var input = document.getElementById('raeTerm');
      if(input) input.focus();
    }, 0);
  }

  function closePanel(){
    panel.hidden = true;
    fab.setAttribute('aria-expanded', 'false');
    fab.focus();
  }

  function togglePanel(){
    if(panel.hidden) openPanel();
    else closePanel();
  }

  fab.addEventListener('click', togglePanel);
  closeBtn.addEventListener('click', closePanel);

  document.addEventListener('keydown', function(e){
    if(e.key === 'Escape' && !panel.hidden) closePanel();
  });

  document.addEventListener('click', function(e){
    if(panel.hidden) return;
    if(panel.contains(e.target) || fab.contains(e.target)) return;
    closePanel();
  });

  function openRAE(mode){
    var el = document.getElementById('raeTerm');
    var t = (el.value || '').trim();
    if(!t) return;

    var base = (mode === 'dpej') ? 'https://dpej.rae.es/' : 'https://dle.rae.es/';
    window.open(base + encodeURIComponent(t), '_blank', 'noopener');
    el.value = t;
  }

  (function(){
    var el = document.getElementById('raeTerm');
    el.addEventListener('keydown', function(e){
      if(e.key === 'Enter'){
        e.preventDefault();
        openRAE('dle');
      }
    });
  })();
</script><header><nav><div style="display: flex; background-color:#fff; justify-content: center;"><a href="http://www.suin-juriscol.gov.co/" target="_blank" title="Enlace para ir al portal Suin-Juriscol"><img alt="Logo Suin-Juriscol" src="https://www.suin-juriscol.gov.co/imagenes/logos/logo_izq.png"></a><a href="http://www.minjusticia.gov.co/" target="_blank" title="Enlace para ir al portal Ministerio de Justicia y del Derecho"><img alt="Logo minjusticia" src="https://www.suin-juriscol.gov.co/imagenes/logos/LogoMinjusticia2024.jpg"></a></div><ul><li><img alt="Inicio" height="50px" src="/imagenes/logos/inicio.png" width="50px"><b><a href="https://www.suin-juriscol.gov.co/" title="Enlace para ir al portal SUIN-Juriscol">Ir al portal SUIN-Juriscol</a></b></li><li><img alt="Ayuda" height="50px" src="/imagenes/logos/ayudar.png" width="50px"><b><a href="https://forms.office.com/r/Rc2jCP6iX0" target="_blank" title="Enlace para ir al formulario Observaciones">Ayúdanos a mejorar</a></b></li><li><img alt="Imprimir" height="50px" src="/imagenes/logos/imprimir.png" width="50px"><b><a href="#" onclick="window.print()" title="Enlace para guardar o imprimir este documento">Guardar en PDF o imprimir la norma</a></b></li><li><img alt="Encuesta" height="50px" src="/imagenes/logos/encuesta.png" width="50px"><b><a href="https://forms.office.com/pages/responsepage.aspx?id=zfse-ze-OEKE0k-sLHVR3K8uzJ3c1ntMoO87w5C1KZ5UMzE4OEpMOUVVWjQ2TUxNS1YyQ0NKRlFDNC4u" title="Enlace para ir al formulario de encuesta">Responder Encuesta</a></b></li><li><img alt="Microsoft Word" height="50px" src="/imagenes/logos/papel.png" width="50px"><b><a href="#" onclick="exportToWord()" title="Enlace para descargar documento en formato Word">Descargar en Word</a></b></li><li><img alt="Compartir" height="50px" src="/imagenes/logos/compartir.png" width="50px"><b><a href="#" onclick="sharePage()" title="Enlace para compartir documento">Compartir este documento</a></b></li><li><img alt="Lectura en voz alta" height="50px" src="/imagenes/logos/audio.png" width="50px"><b><a href="#" onclick="mostrarControlesLectura()" title="Enlace para reproductor de lectura del documento">Lectura de voz</a></b></li></ul></nav><script>
function sharePage() {
  const pageTitle = document.title || 'Documento Jurídico';
  const pageUrl = window.location.href;

  if (navigator.share) {
    navigator.share({
      title: pageTitle,
      text: "Te comparto este documento desde el portal SUIN Juriscol:",
      url: pageUrl
    }).catch((error) => console.log('Error al compartir:', error));
  } else {
    // Compatibilidad con navegadores que no soporten navigator.share
    const subject = encodeURIComponent(pageTitle);
    const body = encodeURIComponent("Consulta este documento en SUIN Juriscol:\n" + pageUrl);
    window.location.href = "mailto:?subject=" + subject + "&body=" + body;
  }
}

function exportToWord() {
  var content = document.documentElement.outerHTML;
  var blob = new Blob(['\ufeff', content], { type: 'application/msword' });
  var link = document.createElement('a');
  link.href = URL.createObjectURL(blob);
  link.download = document.title ? document.title + '.doc' : 'documento.doc';
  document.body.appendChild(link);
  link.click();
  document.body.removeChild(link);
}
</script><style>
#lectorControles {
  display: none;
  position: fixed;
  bottom: 20px;
  right: 20px;
  background: #003366;
  color: #fff;
  padding: 12px 20px;
  border-radius: 12px;
  box-shadow: 0 4px 8px rgba(0,0,0,0.3);
  z-index: 1000;
  font-family: Arial, sans-serif;
}
#lectorControles button {
  background: #0055aa;
  color: white;
  border: none;
  padding: 8px 12px;
  margin: 0 5px;
  border-radius: 8px;
  cursor: pointer;
  font-weight: bold;
}
#lectorControles button:hover {
  background: #0077cc;
}
</style><div id="lectorControles"><span>Lectura de documento:</span><button onclick="iniciarLectura()">Leer</button><button onclick="pausarLectura()">Pausar</button><button onclick="detenerLectura()">Detener</button></div><script>
let voz, leyendo = false, pausado = false;

function mostrarControlesLectura() {
  const controles = document.getElementById('lectorControles');
  controles.style.display = controles.style.display === 'none' ? 'block' : 'none';
}

function obtenerTextoDesdeArriba() {
  const ancla = document.querySelector('a[name="arriba"]');
  if (!ancla) {
    alert("No se encontró el punto de inicio ('a name=arriba').");
    return "";
  }

  let texto = "";
  let nodo = ancla.nextSibling;
  while (nodo) {
    if (nodo.nodeType === Node.TEXT_NODE) texto += nodo.textContent + " ";
    else if (nodo.nodeType === Node.ELEMENT_NODE) texto += nodo.innerText + " ";
    nodo = nodo.nextSibling;
  }
  return texto.trim();
}

function iniciarLectura() {
  const synth = window.speechSynthesis;
  if (leyendo && pausado) {
    synth.resume();
    pausado = false;
    return;
  }

  if (leyendo) {
    alert("Ya se está leyendo el documento.");
    return;
  }

  const texto = obtenerTextoDesdeArriba();
  if (!texto) {
    alert("No hay texto disponible para leer.");
    return;
  }

  voz = new SpeechSynthesisUtterance(texto);
  voz.lang = "es-CO";
  voz.rate = 1.0;
  voz.pitch = 1.0;

  voz.onend = () => {
    leyendo = false;
    pausado = false;
    alert("Lectura finalizada.");
  };

  leyendo = true;
  synth.speak(voz);
}

function pausarLectura() {
  if (speechSynthesis.speaking && !speechSynthesis.paused) {
    speechSynthesis.pause();
    pausado = true;
  }
}

function detenerLectura() {
  if (speechSynthesis.speaking || pausado) {
    speechSynthesis.cancel();
    leyendo = false;
    pausado = false;
  }
}
</script></header><br><div class="slider" style="--width: 320px;     --height: 150px;     --quantity: 3;"><div class="list"><div class="item" style="--position: 1"><div class="card" style="background-image: url('https://www.suin-juriscol.gov.co/imagenes/justiciaprueba.PNG');"><p><b>Curso SUIN-Juriscol</b></p><br><a href="https://forms.office.com/r/JNmz9DJ2J4" target="_blank" title="Ir al formulario de inscripción del Curso SUIN-Juriscol">Inscripciones abiertas</a></div></div><div class="item" style="--position: 2"><div class="card" style="background-image: url('https://www.suin-juriscol.gov.co/imagenes/cursonulidad2026.png');"><p><b>Curso características de los procesos de constitucionalidad y nulidad</b></p><a href="https://forms.office.com/r/QkYs5yrN20" target="_blank" title="Ir al formulario de inscripción del Curso características de los procesos de constitucionalidad y nulidad">Inscripciones abiertas</a></div></div><div class="item" style="--position: 3"><div class="card" style="background-image: url('https://www.suin-juriscol.gov.co/imagenes/cursocalidad2026.png');"><p><b>Curso Calidad Normativa</b></p><br><a href="https://forms.office.com/r/Jnm34xmjkN" target="_blank" title="Ir al formulario de inscripción del Curso Calidad Normativa">Inscripciones abiertas</a></div></div></div></div><a name="arriba"></a><div style="visibility:hidden; height: 0;"><span field="tipo">LEY</span><span field="numero">1420</span><span field="anio">2010</span><span field="fecha">201010
