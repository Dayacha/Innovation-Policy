		</script><script type="text/javascript">
      function toggle_visibility(id, linktext)
      {
      	var e = document.getElementById(id);
      	var link = document.getElementById(linktext);
      	if (link == null) return;

      	if(e.style.display == '')
      	{
      		link.innerHTML = "Mostrar";
      	  e.style.display = 'none';
      	}else
      	{
      	link.innerHTML = "Ocultar";
      	  e.style.display = '';
      	}
      }
      function toggle_visibility_rel(id)
      {
        var e = document.getElementById(id);
        var link = document.getElementById("togglelink_rel");
        if (link == null) return;

        if(e.style.display == '')
        {
          link.innerHTML = "Mostrar normas relacionadas";
          e.style.display = 'none';
        }else
        {
          link.innerHTML = "Ocultar normas relacionadas";
          e.style.display = '';
        }
      }

      function toggle_visibility_modif(id)
      {
        var e = document.getElementById(id);
        var link = document.getElementById("togglelink_modif");
        if (link == null) return;

        if(e.style.display == '')
        {
          link.innerHTML = "Mostrar modificaciones introducidas a la norma";
          e.style.display = 'none';
        }else
        {
          link.innerHTML = "Ocultar modificaciones introducidas a la norma";
          e.style.display = '';
        }
      }

      function toggle_visibility_modif_generales(id)
      {
        var e = document.getElementById(id);
        var link = document.getElementById("togglelink_modif_generales");
        if (link == null) return;

        if(e.style.display == '')
        {
          link.innerHTML = "Mostrar normas relacionadas";
          e.style.display = 'none';
        }else
        {
          link.innerHTML = "Ocultar normas relacionadas";
          e.style.display = '';
        }
      }

      function toggle_nota(id)
      {
        var e = document.getElementById(id);
        if(e.style.display == '')
        {
          e.style.display = 'none';
        }else
        {
          e.style.display = '';
        }
      }

      function show_embbed_nota(id)
      {
        var e = document.getElementById(id);
        if(e.style.display == '')
        {
          e.style.display = 'none';
        }else
        {
          e.style.display = '';
        }
      }

      function toggle(id)
      {
        var item = document.getElementById(id);
        if (!item){alert("no existe "+ id); return;}
        toggleItem(item, item.style.display == "none");
      }

      function toggleItem(item,show)
      {
        if (!item) return;
        item.style.display =  !show ? "none" : "block";
        var label = document.getElementById('toggle_btn_' + item.id.replace('toggle_',''));
        if (label)
          label.innerHTML = !show ? "[+]" : "[-]";
      }

      function toggleAll(show)
      {
        var divs = document.getElementsByTagName("div");
        for (var i in divs)
        {
          if (divs[i].className != "toggle_box") continue;
          toggleItem(divs[i], show);
        }

        var boton_mostrar = document.getElementById("mostrar_todos");
        var boton_ocultar = document.getElementById("ocultar_todos");
        if (show)
        {
          boton_mostrar.style.display =  "none";
          boton_ocultar.style.display =  "block";
        }
        else
        {
          boton_mostrar.style.display =  "block";
          boton_ocultar.style.display =  "none";
        }
      }

      function openPopup(url, title)
      {
        var t = title;
        if (t== null || t=='') t='popup';
        var popup = window.open(url, title, 'width=500,height=300');
        popup.focus();
      }
    </script><script>
